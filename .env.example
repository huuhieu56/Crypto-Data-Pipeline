# =============================================================================
# Environment Variables - Crypto Data Pipeline
# =============================================================================
# Copy file nay thanh .env va dien gia tri that:
#   cp .env.example .env
# =============================================================================

# --- ClickHouse ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9100
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=crypto123
CLICKHOUSE_DB=crypto_db

# --- MinIO Object Storage ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_password_here
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET_RAW=crypto-raw
MINIO_BUCKET_PROCESSED=crypto-processed

# --- Spark ---
SPARK_DRIVER_MEMORY=6g

# --- LLM (OpenAI-compatible API) ---
LLM_BASE_URL=https://your-api-endpoint/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=your_model_name

# --- Chat API ---
CHAT_API_PORT=8501

# --- LangSmith (Tracing & Observability) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=crypto-chatbot

# --- GNews API (Crypto News) ---
GNEWS_API_KEY=your_gnews_api_key_here

# --- ETL ---
# How many months of historical data to ETL (default: 3 = 3 months)
ETL_MONTHS_BACK=3

# --- Logging ---
LOG_LEVEL=INFO
