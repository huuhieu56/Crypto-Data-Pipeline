          "editorMode": "code",
          "format": 0,
          "rawQuery": true,
          "rawSql": "SELECT\n  fromUnixTimestamp64Milli(toInt64(${__from})) AS time,\n  fromUnixTimestamp64Milli(toInt64(${__to})) AS end_time,\n  s.base_asset AS Coin,\n  round(k.rsi_14, 1) AS RSI\nFROM (\n  SELECT DISTINCT symbol, base_asset\n  FROM symbols\n) s\nJOIN (\n  SELECT symbol, argMax(rsi_14, timestamp) AS rsi_14\n  FROM klines FINAL\n  GROUP BY symbol\n) k ON k.symbol = s.symbol\nORDER BY k.rsi_14 DESC\nLIMIT 30",
          "refId": "A"
        }
      ],
